"""Change assessment.assessment_type from varchar(30)+CHECK to native PostgreSQL ENUM.

Tạo kiểu enum biosec.assessment_type_enum, chuyển cột assessment_type sang enum.
"""

from alembic import op

revision = "0012"
down_revision = "0011"
branch_labels = None
depends_on = None


def upgrade() -> None:
    # 1. Create the PostgreSQL ENUM type
    op.execute("""
        CREATE TYPE biosec.assessment_type_enum AS ENUM (
            'self',
            'scheduled_audit',
            'spot',
            'blind',
            'incident_review'
        )
    """)

    # 2. Drop existing CHECK constraint (ck_assessment_1 covers assessment_type)
    op.execute("""
        ALTER TABLE biosec.assessment
        DROP CONSTRAINT IF EXISTS ck_assessment_1
    """)

    # 3. Alter column type using USING cast
    op.execute("""
        ALTER TABLE biosec.assessment
        ALTER COLUMN assessment_type
        TYPE biosec.assessment_type_enum
        USING assessment_type::biosec.assessment_type_enum
    """)

    op.execute("""
        COMMENT ON COLUMN biosec.assessment.assessment_type IS
        'Loại đánh giá (PostgreSQL ENUM): self | scheduled_audit | spot | blind | incident_review'
    """)


def downgrade() -> None:
    # Revert column back to varchar(30) + CHECK constraint
    op.execute("""
        ALTER TABLE biosec.assessment
        ALTER COLUMN assessment_type
        TYPE varchar(30)
        USING assessment_type::varchar(30)
    """)

    op.execute("""
        ALTER TABLE biosec.assessment
        ADD CONSTRAINT ck_assessment_1
        CHECK (assessment_type IN ('self','scheduled_audit','spot','blind','incident_review'))
    """)

    op.execute("DROP TYPE IF EXISTS biosec.assessment_type_enum")
